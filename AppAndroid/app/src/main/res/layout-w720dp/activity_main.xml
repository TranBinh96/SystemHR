<?xml version="1.0" encoding="utf-8"?>
<!-- Layout for HD screens (720dp width) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal">

    <!-- Left Side Navigation -->
    <LinearLayout
        android:layout_width="240dp"
        android:layout_height="match_parent"
        android:background="#F8FAFB"
        android:elevation="4dp"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="24dp">

        <!-- Logo & Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="Logo"
                    android:src="@drawable/ic_gallery_black_24dp"
                    app:tint="@color/culinary_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="OKI VN"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textColor="#1F2937"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="38dp"
                android:layout_marginTop="4dp"
                android:text="QUẢN LÝ MÁY TÍNH BẢNG"
                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                android:textColor="#9CA3AF"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Navigation Menu -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Dashboard -->
            <LinearLayout
                android:id="@+id/nav_dashboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/nav_item_background"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingVertical="10dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="Dashboard"
                    android:src="@drawable/ic_camera_black_24dp"
                    app:tint="#9CA3AF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Trang Chủ"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="#6B7280" />
            </LinearLayout>

            <!-- Meal Logs -->
            <LinearLayout
                android:id="@+id/nav_meal_logs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/nav_item_background"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingVertical="10dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="Meal Logs"
                    android:src="@drawable/ic_slideshow_black_24dp"
                    app:tint="#9CA3AF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Nhật Ký Bữa Ăn"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="#6B7280" />
            </LinearLayout>

            <!-- QR Scanner (Active) -->
            <LinearLayout
                android:id="@+id/nav_qr_scanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/nav_item_active"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingVertical="10dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="QR Scanner"
                    android:src="@drawable/ic_qr_code_scanner"
                    app:tint="@color/culinary_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Quét Mã QR"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="@color/culinary_primary"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Settings -->
            <LinearLayout
                android:id="@+id/nav_settings_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/nav_item_background"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingVertical="10dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="Settings"
                    android:src="@drawable/ic_settings_black_24dp"
                    app:tint="#9CA3AF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Cài Đặt"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="#6B7280" />
            </LinearLayout>
        </LinearLayout>

        <!-- Bottom Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- New Meal Plan Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_new_meal_plan"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Kế Hoạch Bữa Ăn Mới"
                android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                android:textStyle="bold"
                app:backgroundTint="@color/culinary_primary"
                app:cornerRadius="10dp"
                app:icon="@drawable/ic_check_circle"
                app:iconGravity="textStart"
                app:iconSize="18dp"
                app:iconTint="@color/white" />

            <!-- User Profile -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_avatar_placeholder">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:contentDescription="Chef"
                            android:src="@drawable/avatar_1"
                            app:tint="@color/white" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bếp Trưởng Nguyễn"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="#1F2937"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trưởng Bếp Điều Hành"
                        android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                        android:textColor="#9CA3AF" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Main Content Area -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Top App Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@color/white"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="32dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="MÁY TÍNH BẢNG ẨM THỰC"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="#1F2937"
                android:textStyle="bold" />

            <!-- Top Navigation Tabs -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="20dp"
                    android:text="TỔNG QUAN"
                    android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                    android:textColor="#9CA3AF"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LỊCH SỬ"
                    android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                    android:textColor="@color/culinary_primary"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Icons -->
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="12dp"
                android:contentDescription="Notifications"
                android:src="@drawable/ic_settings_black_24dp"
                app:tint="#9CA3AF" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="Help"
                android:src="@drawable/ic_settings_black_24dp"
                app:tint="#9CA3AF" />
        </LinearLayout>

        <!-- Fragment Container -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/nav_host_fragment_content_main"
            android:name="androidx.navigation.fragment.NavHostFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:defaultNavHost="true"
            app:navGraph="@navigation/mobile_navigation" />
    </LinearLayout>

</LinearLayout>
