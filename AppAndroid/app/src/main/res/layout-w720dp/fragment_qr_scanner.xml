<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/culinary_surface"
    android:orientation="horizontal"
    android:padding="20dp"
    tools:context=".ui.scanner.QRScannerFragment">

    <!-- Left Column: QR Scanner Area -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginEnd="14dp"
        android:layout_weight="1.2"
        app:cardCornerRadius="14dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Quét Trực Tiếp"
                    android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                    android:textColor="@color/culinary_on_surface"
                    android:textStyle="bold" />

                <!-- Status Badge -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_status_active"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp">

                    <View
                        android:layout_width="7dp"
                        android:layout_height="7dp"
                        android:layout_marginEnd="5dp"
                        android:background="@drawable/bg_pulse_dot" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HỆ THỐNG HOẠT ĐỘNG"
                        android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                        android:textColor="@color/culinary_primary"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Scanner Camera View -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="20dp"
                android:layout_weight="1"
                android:background="@color/black">

                <!-- Camera Preview Placeholder -->
                <View
                    android:id="@+id/camera_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_camera_preview" />

                <!-- Scanner Frame Overlay -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/scanner_overlay" />

                <!-- Scanner Frame with Corners -->
                <FrameLayout
                    android:layout_width="240dp"
                    android:layout_height="240dp"
                    android:layout_gravity="center">

                    <!-- Corner Top Left -->
                    <View
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="start|top"
                        android:background="@drawable/scanner_corner_tl" />

                    <!-- Corner Top Right -->
                    <View
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="end|top"
                        android:background="@drawable/scanner_corner_tr" />

                    <!-- Corner Bottom Left -->
                    <View
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="start|bottom"
                        android:background="@drawable/scanner_corner_bl" />

                    <!-- Corner Bottom Right -->
                    <View
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="end|bottom"
                        android:background="@drawable/scanner_corner_br" />

                    <!-- Scanning Line -->
                    <View
                        android:id="@+id/scanning_line"
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:layout_gravity="center"
                        android:layout_marginHorizontal="14dp"
                        android:background="@drawable/bg_scanning_line" />
                </FrameLayout>

                <!-- Instructions -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="28dp"
                    android:background="@drawable/bg_instruction_label"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="8dp"
                    android:text="Căn chỉnh mã QR trong khung để quét"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:textColor="@color/white" />

                <!-- Camera Type Indicator -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_instruction_label"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="📷 CAMERA TRƯỚC"
                    android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                    android:textColor="@color/white"
                    android:textStyle="bold" />
            </FrameLayout>

            <!-- Camera Controls -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- Flash Button -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="32dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/btn_flash"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="Toggle flash"
                        app:backgroundTint="@color/culinary_surface_container_highest"
                        app:fabSize="normal"
                        app:srcCompat="@drawable/ic_flashlight_on"
                        app:tint="@color/culinary_on_surface_variant" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="ĐÈN FLASH"
                        android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                        android:textColor="@color/culinary_on_surface_variant"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Switch Camera Button -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/btn_switch_camera"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="Switch camera"
                        app:backgroundTint="@color/culinary_surface_container_highest"
                        app:fabSize="normal"
                        app:srcCompat="@drawable/ic_flip_camera_ios"
                        app:tint="@color/culinary_on_surface_variant" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="ĐỔI CAMERA"
                        android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                        android:textColor="@color/culinary_on_surface_variant"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Right Column: Meal Information -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Result Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:cardCornerRadius="14dp"
            app:cardElevation="1dp">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Status Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_confirmed_badge"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="7dp">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_marginEnd="5dp"
                                android:contentDescription="Confirmed"
                                android:src="@drawable/ic_check_circle"
                                app:tint="@color/culinary_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ĐÃ XÁC NHẬN"
                                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                android:textColor="@color/culinary_primary"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12:30 CH • Hôm nay"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                            android:textColor="@color/culinary_on_surface_variant" />
                    </LinearLayout>

                    <!-- Meal Image -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:layout_marginTop="20dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_meal_placeholder">

                            <ImageView
                                android:id="@+id/img_meal"
                                android:layout_width="70dp"
                                android:layout_height="70dp"
                                android:layout_gravity="center"
                                android:contentDescription="Meal image"
                                android:src="@drawable/ic_gallery_black_24dp"
                                app:tint="#81C784" />
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Meal Title -->
                    <TextView
                        android:id="@+id/tv_meal_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:text="Cơm gà xối mỡ"
                        android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                        android:textColor="@color/culinary_on_surface"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_meal_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:text="Đặc Sản Bữa Trưa • Quầy Bếp 1"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="@color/culinary_on_surface_variant" />

                    <!-- Employee Info Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        app:cardBackgroundColor="@color/culinary_surface_container_low"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="14dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                app:cardCornerRadius="24dp"
                                app:cardElevation="0dp"
                                app:strokeColor="@color/culinary_primary"
                                app:strokeWidth="2dp">

                                <FrameLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@drawable/bg_avatar_placeholder">

                                    <ImageView
                                        android:id="@+id/img_employee"
                                        android:layout_width="28dp"
                                        android:layout_height="28dp"
                                        android:layout_gravity="center"
                                        android:contentDescription="Employee avatar"
                                        android:src="@drawable/avatar_1"
                                        app:tint="@color/white" />
                                </FrameLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="14dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="NHÂN VIÊN"
                                    android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                    android:textColor="@color/culinary_on_surface_variant"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tv_employee_name"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:text="Nguyen Van Anh"
                                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                                    android:textColor="@color/culinary_on_surface"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Department & Credit Info -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="7dp"
                            android:layout_weight="1"
                            app:cardBackgroundColor="@color/culinary_surface_container_low"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="PHÒNG BAN"
                                    android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                    android:textColor="@color/culinary_on_surface_variant"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tv_department"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:text="Thiết Kế Sáng Tạo"
                                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                                    android:textColor="@color/culinary_on_surface"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="7dp"
                            android:layout_weight="1"
                            app:cardBackgroundColor="@color/culinary_surface_container_low"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="SUẤT ĂN"
                                    android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                    android:textColor="@color/culinary_on_surface_variant"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tv_meal_credit"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:text="-1 Số Dư"
                                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                                    android:textColor="@color/culinary_primary"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <!-- Action Buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_report_issue"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_marginEnd="7dp"
                            android:layout_weight="1"
                            android:text="Báo Lỗi"
                            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textStyle="bold"
                            app:cornerRadius="10dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_complete"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_marginStart="7dp"
                            android:layout_weight="1"
                            android:text="Hoàn Thành"
                            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textStyle="bold"
                            app:backgroundTint="@color/culinary_primary"
                            app:cornerRadius="10dp"
                            app:icon="@drawable/ic_done_all"
                            app:iconGravity="textStart" />
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>
        </com.google.android.material.card.MaterialCardView>

        <!-- Recent Activity Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/culinary_tertiary_container"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/culinary_tertiary"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    app:cardBackgroundColor="@color/culinary_tertiary"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="History"
                        android:src="@drawable/ic_history"
                        app:tint="@color/culinary_on_tertiary" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="QUÉT TRƯỚC"
                        android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                        android:textColor="@color/culinary_tertiary"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Trần Thị Bình • 12:28 CH"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="@color/culinary_on_surface"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="View details"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/culinary_on_surface_variant" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</LinearLayout>
